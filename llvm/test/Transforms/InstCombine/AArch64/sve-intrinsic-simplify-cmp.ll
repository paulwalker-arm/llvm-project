; CHECK-NEXT:    ret <vscale x 16 x i1> [[R]]
;
  %r = call <vscale x 16 x i1> @llvm.aarch64.sve.cmpgt.wide.nxv16i8(<vscale x 16 x i1> %pg, <vscale x 16 x i8> splat (i8 127), <vscale x 2 x i64> %a)
  ret <vscale x 16 x i1> %r
}

